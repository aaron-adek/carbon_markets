[Unit]
Description=Carbon Markets Streamlit Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rasp
WorkingDirectory=/home/rasp/carbon_markets/dashboard
ExecStart=/home/rasp/carbon_markets/.venv/bin/streamlit run app.py --server.port 8501 --server.headless true
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
